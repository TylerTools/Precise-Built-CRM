generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ─── Users & Auth ────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("tech") // owner | admin | manager | tech | client
  displayName  String?   @map("display_name")
  phone        String?
  profileImage String?   @map("profile_image")
  createdAt    DateTime  @default(now()) @map("created_at")

  projects      Project[]   @relation("AssignedUser")
  timeEntries   TimeEntry[]
  assignedTasks Task[]      @relation("TaskAssignee")

  @@map("users")
}

// ─── CRM / Contacts ─────────────────────────────────────────
model Contact {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String
  source    String    @default("other")
  status    String    @default("new")
  notes     String    @default("")
  createdAt DateTime  @default(now()) @map("created_at")

  projects  Project[]

  @@map("contacts")
}

// ─── Projects (10-Stage Workflow) ────────────────────────────
model Project {
  id             String    @id @default(uuid())
  contactId      String    @map("contact_id")
  jobType        String    @map("job_type")
  address        String    @default("")
  scope          String    @default("")
  value          Float?
  stage          String    @default("S1")
  assignedUserId String?   @map("assigned_user_id")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  notes          String    @default("")
  archived       Boolean   @default(false)
  archivedAt     DateTime? @map("archived_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  contact        Contact        @relation(fields: [contactId], references: [id])
  assignedUser   User?          @relation("AssignedUser", fields: [assignedUserId], references: [id])
  tasks          Task[]
  files          File[]
  changeOrders   ChangeOrder[]
  purchaseOrders PurchaseOrder[]
  timeEntries    TimeEntry[]
  documents      Document[]
  stageHistory   StageHistory[]
  media          ProjectMedia[]

  @@map("projects")
}

// ─── Tasks (Exit Checklists & Custom Tasks) ──────────────────
model Task {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  label          String
  completed      Boolean   @default(false)
  isChecklist    Boolean   @default(false) @map("is_checklist")
  stage          String?
  sortOrder      Int       @default(0) @map("sort_order")
  assignedUserId String?   @map("assigned_user_id")
  dueDate        DateTime? @map("due_date")
  priority       String    @default("medium")
  createdAt      DateTime  @default(now()) @map("created_at")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedUser User?   @relation("TaskAssignee", fields: [assignedUserId], references: [id])

  @@map("tasks")
}

// ─── Files ───────────────────────────────────────────────────
model File {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  filename   String
  url        String
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("files")
}

// ─── Documents ───────────────────────────────────────────────
model Document {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  type       String
  label      String
  url        String
  stage      String?
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─── Change Orders ───────────────────────────────────────────
model ChangeOrder {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  description String
  amount      Float
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("change_orders")
}

// ─── Purchase Orders ─────────────────────────────────────────
model PurchaseOrder {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  vendor      String
  description String
  amount      Float
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("purchase_orders")
}

// ─── Time Entries ────────────────────────────────────────────
model TimeEntry {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  date      DateTime @db.Date
  hours     Float
  note      String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

// ─── Stage History ───────────────────────────────────────────
model StageHistory {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  fromStage String   @map("from_stage")
  toStage   String   @map("to_stage")
  movedAt   DateTime @default(now()) @map("moved_at")
  movedBy   String?  @map("moved_by")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("stage_history")
}

// ─── Project Media ──────────────────────────────────────────
model ProjectMedia {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  fileName    String   @map("file_name")
  fileType    String   @map("file_type")
  blobUrl     String   @map("blob_url")
  driveFileId String?  @map("drive_file_id")
  driveUrl    String?  @map("drive_url")
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_media")
}

// ─── Settings (Singleton) ───────────────────────────────────
model Settings {
  id                 String   @id @default("singleton")
  companyName        String   @default("Precise Built Construction") @map("company_name")
  companyPhone       String   @default("") @map("company_phone")
  companyEmail       String   @default("") @map("company_email")
  companyAddress     String   @default("") @map("company_address")
  logoUrl            String   @default("") @map("logo_url")
  accentColor        String   @default("#c47a4f") @map("accent_color")
  mainBgColor        String   @default("#0e0e0f") @map("main_bg_color")
  cardColor          String   @default("#161617") @map("card_color")
  sidebarColor       String   @default("#111112") @map("sidebar_color")
  darkMode           Boolean  @default(true) @map("dark_mode")
  inviteEmailSubject String   @default("You've been invited to Precise Built Field OS") @map("invite_email_subject")
  inviteEmailBody    String   @default("Hi {{name}}, your account has been created. Email: {{email}} Password: {{password}} Login at: {{loginUrl}}") @map("invite_email_body")
  stageEmailSubject  String   @default("Project stage updated") @map("stage_email_subject")
  stageEmailBody     String   @default("Project {{project}} has moved to {{stage}}") @map("stage_email_body")
  driveConnected     Boolean  @default(false) @map("drive_connected")
  driveRefreshToken  String?  @map("drive_refresh_token")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ─── Settings Backup ────────────────────────────────────────
model SettingsBackup {
  id          String   @id @default(uuid())
  snapshot    Json
  backedUpAt  DateTime @default(now()) @map("backed_up_at")
  triggeredBy String   @default("auto") @map("triggered_by")

  @@map("settings_backups")
}
